# Railway Environment Variable Guide

# Database (Provided by Railway PostgreSQL Plugin)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Redis (Provided by Railway Redis Plugin)
REDIS_URL=redis://default:password@host:port

# Scraper Proxy (Bright Data)
PROXY_HOST=brd-customer-xxxx-zone-xxxx
PROXY_USER=username
PROXY_PASS=password

# Scraper Settings
SCRAPER_DELAY_MIN=2
SCRAPER_DELAY_MAX=5
SCRAPER_HEADLESS=true
SCRAPER_TEST_MODE=false
SCRAPER_ENABLE_EMAIL=true
SCRAPER_ENABLE_DEDUPE=true
SCRAPER_SCHEDULER_ENABLED=false
SCRAPER_AMFI_PAGE_SIZE=10000
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_POOL=solo
