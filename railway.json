{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  },
  "plugins": [
    {
      "id": "postgresql",
      "description": "PostgreSQL database"
    },
    {
      "id": "redis",
      "description": "Redis for Celery"
    }
  ]
}